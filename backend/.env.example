# Copy this file to .env and fill in the values.
# Never commit .env to version control.

DEBUG=True
SECRET_KEY=your-secret-key-here-generate-with-python-secrets-token-hex-50
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=addis_kidan
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Email (use console backend in development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@addiskidan.org

# Production email (Postmark / SES)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.postmarkapp.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# S3-compatible object storage (leave blank to use local media in development)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# Sentry (leave blank to disable)
SENTRY_DSN=

# Reconciliation thresholds (percentage 0–100)
RECONCILIATION_AUTO_APPLY_THRESHOLD=90
RECONCILIATION_REVIEW_THRESHOLD=60

# Twilio (Phase 2 — leave blank for now)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Organization
DEFAULT_ORGANIZATION_NAME=Addis Kidan Mutual Support Association
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
